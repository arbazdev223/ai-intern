# Rename to .env and fill in your keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_RESEARCH_MODEL=gpt-4.1
OPENAI_VISION_MODEL=gpt-4o-mini
# Gemini (optional)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash
# GPT_key is deprecated and kept only for backward compatibility.
# GPT_key=

# ElevenLabs (voice)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
# Optional: choose a specific model (leave blank for ElevenLabs default)
# ELEVENLABS_MODEL_ID=
# Optional: speech-to-text model (defaults to scribe_v2)
# ELEVENLABS_STT_MODEL_ID=scribe_v2

# Response cache (optional)
# RESPONSE_CACHE_TTL_MS=1200000
# RESPONSE_CACHE_MAX_ENTRIES=300

# Prompt library remote sync (optional)
# PROMPT_LIBRARY_API_BASE=https://ims.ifda.in/api/prompt-library
# PROMPT_LIBRARY_BEARER_TOKEN=
# PROMPT_LIBRARY_MASTER_SECRET=
# PROMPT_LIBRARY_USER_ID=

# Auto-update via GitHub Releases (optional for packaged app)
# IFDA_AUTO_UPDATE_ENABLED=false
# IFDA_UPDATE_OWNER=your-github-username-or-org
# IFDA_UPDATE_REPO=your-repository-name
# Optional for private repos:
# GITHUB_TOKEN=ghp_xxx
