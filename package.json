{
  "name": "ifda-ai",
  "version": "1.0.13",
  "author": "IFDA",
  "description": "Electron desktop chat app using OpenAI and Gemini APIs",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& set NODE_ENV=development&& electron .",
    "build": "electron-builder --publish never",
    "bundle:keys": "node scripts/generateBundledSecrets.js",
    "dist": "node scripts/generateBundledSecrets.js && electron-builder --win --publish never --config.directories.output=%TEMP%\\ai-intern-dist",
    "release:win": "node scripts/generateBundledSecrets.js && electron-builder --win --publish always --config.directories.output=%TEMP%\\ai-intern-dist --config.publish.provider=github --config.publish.owner=%IFDA_UPDATE_OWNER% --config.publish.repo=%IFDA_UPDATE_REPO% --config.publish.releaseType=release",
    "generate:sri": "node scripts/generateSRI.js",
    "check:sri": "node scripts/generateSRI.js --check",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ai": "node -r dotenv/config ai_test_runner.js"
  },
  "build": {
    "directories": {
      "output": "dist"
    },
    "icon": "blue-logo.ico",
    "appId": "com.ai.intern",
    "productName": "AI Intern",
    "files": [
      "**/*",
      "!.git/**",
      "!.github/**",
      "!dist/**",
      "!artifacts/**",
      "!__tests__/**",
      "!docs/**",
      "!coverage/**",
      "!scripts/**",
      "!electron-smoke-*.log",
      "!*.log",
      "!.env",
      "!.env.example",
      "!.gitignore",
      "!README.md",
      "!CONTRIBUTING.md"
    ],
    "win": {
      "icon": "blue-logo.ico",
      "target": "nsis",
      "artifactName": "IFDA-AI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "IFDA AI"
    }
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-reload": "^2.0.0-alpha.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "active-win": "^8.2.1",
    "docx": "^9.5.1",
    "dompurify": "^3.3.2",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.4",
    "mermaid": "^11.13.0",
    "openai": "^4.86.0",
    "pdfkit": "^0.16.0",
    "tesseract.js": "^7.0.0"
  }
}
